# .env file for secrets not comitted to the repo
# REQUIRED: make your own .env file in the root of the repo with the below


# --- SMTP Configuration ---
SMTP_HOST="smtp.your_org.edu"
SMTP_PORT=587
SMTP_USERNAME="your_user"
SMTP_PASSWORD="your_secret"

# --- File Configuration ---
CALENDAR_CSV="\\\\your-smb-server\\Calendar\\calendar-data.csv"