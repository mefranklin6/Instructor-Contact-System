# .env file for secrets not comitted to the repo (is in .gitignore)
# REQUIRED: make your own .env file in the root of the repo with the below


# ---- SMTP Configuration ----
SMTP_HOST=smtp.your_org.edu
SMTP_PORT=587
SMTP_FROM=email@your_org.edu
SMTP_USERNAME=username
SMTP_PASSWORD=pw

# ---- Logging ----
LOGGING_LEVEL=INFO

# ---- Developer Settings ----
DEV_MODE=False

# ---- Module Configuration ----
SUPPORTED_LOCATIONS_MODE=none
SUPPORTED_LOCATIONS_FILE_PATH=none

ID_TO_EMAIL_MODULE=Zoom
ID_TO_EMAIL_FILE_PATH=zoomus_users.csv

# ---- FacilitiesLink Schedule CSV File Path ----
FL_FILE_PATH=FacilitiesLinkClassScheduleDaily.csv

